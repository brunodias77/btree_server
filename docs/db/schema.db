-- ============================================================
-- SCHEMAS
-- ============================================================

CREATE SCHEMA IF NOT EXISTS shared;
CREATE SCHEMA IF NOT EXISTS users;
CREATE SCHEMA IF NOT EXISTS catalog;
CREATE SCHEMA IF NOT EXISTS cart;
CREATE SCHEMA IF NOT EXISTS orders;
CREATE SCHEMA IF NOT EXISTS payments;
CREATE SCHEMA IF NOT EXISTS coupons;

-- ============================================================
-- EXTENSÕES
-- ============================================================

CREATE EXTENSION IF NOT EXISTS "citext";
CREATE EXTENSION IF NOT EXISTS "pg_trgm";

-- ============================================================
-- UUIDv7 (RFC 9562) — time-ordered, melhor para B-tree indexes
-- Substitui uuid-ossp (uuid_generate_v4). Requer PostgreSQL 13+.
-- ============================================================

CREATE OR REPLACE FUNCTION uuid_generate_v7()
RETURNS UUID AS $$
  SELECT encode(
    set_byte(
      set_byte(
        overlay(
          uuid_send(gen_random_uuid())
          placing substring(int8send(floor(extract(epoch FROM clock_timestamp()) * 1000)::bigint) from 3)
          from 1 for 6
        ),
        6, (get_byte(uuid_send(gen_random_uuid()), 6) & 15) | 112  -- version 7
      ),
      8, (get_byte(uuid_send(gen_random_uuid()), 8) & 63) | 128    -- variant 10xx
    ),
  'hex')::uuid;
$$ LANGUAGE sql VOLATILE;

-- ============================================================
-- GERAÇÃO DE NÚMERO DE PEDIDO
-- Formato: ORD-YYYYMMDD-XXXXXXXXX (25 chars)
-- Deve ser criada ANTES da tabela orders.orders.
-- ============================================================

CREATE OR REPLACE FUNCTION orders.generate_order_number()
RETURNS VARCHAR(25) AS $$
DECLARE
    v_date   TEXT := TO_CHAR(NOW(), 'YYYYMMDD');
    v_random TEXT := UPPER(SUBSTRING(REPLACE(gen_random_uuid()::TEXT, '-', '') FROM 1 FOR 9));
BEGIN
    RETURN 'ORD-' || v_date || '-' || v_random;
END;
$$ LANGUAGE plpgsql VOLATILE;

-- ============================================================
-- ENUMS COMPARTILHADOS (shared types)
-- ============================================================

-- [C1]
CREATE TYPE shared.product_status AS ENUM (
    'DRAFT',
    'ACTIVE',
    'PAUSED',
    'ARCHIVED'
);

CREATE TYPE shared.stock_movement_type AS ENUM (
    'IN',
    'OUT',
    'RESERVE',
    'RELEASE',
    'ADJUSTMENT',
    'RETURN'
);

CREATE TYPE shared.cart_status AS ENUM (
    'ACTIVE',
    'CONVERTED',
    'ABANDONED',
    'EXPIRED'
);

CREATE TYPE shared.order_status AS ENUM (
    'PENDING',
    'CONFIRMED',
    'PROCESSING',
    'SHIPPED',
    'DELIVERED',
    'CANCELLED',
    'REFUNDED',
    'PARTIALLY_REFUNDED'
);

CREATE TYPE shared.shipping_method AS ENUM (
    'STANDARD',
    'EXPRESS',
    'OVERNIGHT',
    'PICKUP',
    'FREE'
);

CREATE TYPE shared.payment_method_type AS ENUM (
    'CREDIT_CARD',
    'DEBIT_CARD',
    'PIX',
    'BOLETO',
    'WALLET',
    'BANK_TRANSFER'
);

CREATE TYPE shared.payment_status AS ENUM (
    'PENDING',
    'AUTHORIZED',
    'CAPTURED',
    'FAILED',
    'CANCELLED',
    'REFUNDED',
    'PARTIALLY_REFUNDED',
    'CHARGEBACK'
);

CREATE TYPE shared.transaction_type AS ENUM (
    'AUTHORIZATION',
    'CAPTURE',
    'REFUND',
    'CHARGEBACK',
    'VOID',
    'REVERSAL'
);

CREATE TYPE shared.coupon_type AS ENUM (
    'PERCENTAGE',
    'FIXED_AMOUNT',
    'FREE_SHIPPING',
    'BUY_X_GET_Y'
);

CREATE TYPE shared.coupon_scope AS ENUM (
    'ALL',
    'CATEGORY',
    'PRODUCT',
    'USER'
);

CREATE TYPE shared.coupon_status AS ENUM (
    'DRAFT',
    'ACTIVE',
    'PAUSED',
    'EXPIRED',
    'DEPLETED'
);

CREATE TYPE shared.card_brand AS ENUM (
    'VISA',
    'MASTERCARD',
    'AMEX',
    'ELO',
    'HIPERCARD',
    'DINERS',
    'OTHER'
);

CREATE TYPE shared.cancellation_reason AS ENUM (
    'CUSTOMER_REQUEST',
    'FRAUD',
    'OUT_OF_STOCK',
    'PAYMENT_FAILED',
    'DUPLICATE_ORDER',
    'OTHER'
);

-- [R1] Novo enum para tipos de token de usuário.
-- Garante consistência com os demais tipos do sistema.
CREATE TYPE shared.token_type AS ENUM (
    'EMAIL_VERIFICATION',
    'PASSWORD_RESET',
    'TWO_FACTOR',
    'MAGIC_LINK',
    'ACCOUNT_UNLOCK',
    'PHONE_VERIFICATION'
);

CREATE TYPE shared.refund_status AS ENUM (
    'PENDING',
    'PROCESSING',
    'COMPLETED',
    'FAILED'
);

CREATE TYPE shared.chargeback_status AS ENUM (
    'OPEN',
    'UNDER_REVIEW',
    'WON',
    'LOST',
    'EXPIRED'
);



-- ============================================================
-- MÓDULO DE USUÁRIOS (users)
-- ============================================================

CREATE TABLE users.users (
    id                    UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    username              VARCHAR(256) NOT NULL,
    email                 VARCHAR(256) NOT NULL,
    email_verified        BOOLEAN      NOT NULL DEFAULT FALSE,
    password_hash         TEXT         NOT NULL,
    phone_number          VARCHAR(50),
    phone_number_verified BOOLEAN      NOT NULL DEFAULT FALSE,
    two_factor_enabled    BOOLEAN      NOT NULL DEFAULT FALSE,
    account_locked        BOOLEAN      NOT NULL DEFAULT FALSE,
    lock_expires_at       TIMESTAMPTZ,
    access_failed_count   INT          NOT NULL DEFAULT 0,
    enabled               BOOLEAN      NOT NULL DEFAULT TRUE,
    created_at            TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at            TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE UNIQUE INDEX uq_users_username ON users.users(LOWER(username));
CREATE UNIQUE INDEX uq_users_email    ON users.users(LOWER(email));
CREATE INDEX idx_users_enabled        ON users.users(enabled) WHERE enabled = TRUE;

CREATE TABLE users.roles (
    id          UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    name        VARCHAR(256) NOT NULL,
    description TEXT,
    created_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE UNIQUE INDEX uq_roles_name ON users.roles(LOWER(name));

CREATE TABLE users.user_roles (
    user_id UUID NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    role_id UUID NOT NULL REFERENCES users.roles(id) ON DELETE CASCADE,
    PRIMARY KEY (user_id, role_id)
);

CREATE INDEX idx_user_roles_role_id ON users.user_roles(role_id);

CREATE TABLE users.user_authorities (
    id        SERIAL       PRIMARY KEY,
    user_id   UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    authority VARCHAR(255) NOT NULL,
    CONSTRAINT uq_user_authority UNIQUE (user_id, authority)
);

CREATE INDEX idx_user_authorities_user_id ON users.user_authorities(user_id);

CREATE TABLE users.user_social_logins (
    id                    UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id               UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    provider              VARCHAR(128) NOT NULL,
    provider_user_id      VARCHAR(256) NOT NULL,
    provider_display_name VARCHAR(255),
    created_at            TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_social_login UNIQUE (provider, provider_user_id)
);

CREATE INDEX idx_user_social_logins_user_id ON users.user_social_logins(user_id);

CREATE TABLE users.user_tokens (
    id         UUID               PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id    UUID               NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    token_type shared.token_type  NOT NULL,
    token_hash VARCHAR(512)       NOT NULL,
    expires_at TIMESTAMPTZ        NOT NULL,
    used_at    TIMESTAMPTZ,
    created_at TIMESTAMPTZ        NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_user_tokens_hash    ON users.user_tokens(token_hash) WHERE used_at IS NULL;
CREATE INDEX idx_user_tokens_user_id ON users.user_tokens(user_id);
CREATE INDEX idx_user_tokens_expires ON users.user_tokens(expires_at) WHERE used_at IS NULL;

CREATE TABLE users.profiles (
    id                    UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id               UUID         NOT NULL UNIQUE REFERENCES users.users(id) ON DELETE CASCADE,
    first_name            VARCHAR(100),
    last_name             VARCHAR(100),
    display_name          VARCHAR(100),
    avatar_url            TEXT,
    birth_date            DATE,
    gender                VARCHAR(20),
    cpf                   VARCHAR(14),
    preferred_language    VARCHAR(5)   DEFAULT 'pt-BR',
    preferred_currency    VARCHAR(3)   DEFAULT 'BRL',
    newsletter_subscribed BOOLEAN      DEFAULT FALSE,
    accepted_terms_at     TIMESTAMPTZ,
    accepted_privacy_at   TIMESTAMPTZ,
    version               INT          NOT NULL DEFAULT 1,
    created_at            TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at            TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    deleted_at            TIMESTAMPTZ,
    CONSTRAINT chk_profiles_cpf_format CHECK (
        cpf IS NULL OR cpf ~ '^\d{3}\.\d{3}\.\d{3}-\d{2}$'
    )
);

CREATE UNIQUE INDEX uq_profiles_cpf ON users.profiles(cpf)
    WHERE cpf IS NOT NULL AND deleted_at IS NULL;

CREATE TABLE users.addresses (
    id                 UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id            UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    label              VARCHAR(50),
    recipient_name     VARCHAR(150),
    street             VARCHAR(255) NOT NULL,
    number             VARCHAR(20),
    complement         VARCHAR(100),
    neighborhood       VARCHAR(100),
    city               VARCHAR(100) NOT NULL,
    state              VARCHAR(2)   NOT NULL,
    postal_code        VARCHAR(9)   NOT NULL,
    country            VARCHAR(2)   NOT NULL DEFAULT 'BR',
    latitude           DECIMAL(10, 8),
    longitude          DECIMAL(11, 8),
    ibge_code          VARCHAR(7),
    is_default         BOOLEAN      DEFAULT FALSE,
    is_billing_address BOOLEAN      DEFAULT FALSE,
    created_at         TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at         TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    deleted_at         TIMESTAMPTZ,
    CONSTRAINT chk_addresses_postal_code CHECK (postal_code ~ '^\d{5}-?\d{3}$'),
    CONSTRAINT chk_addresses_state       CHECK (state ~ '^[A-Z]{2}$')
);

CREATE INDEX idx_addresses_user_id ON users.addresses(user_id) WHERE deleted_at IS NULL;
CREATE UNIQUE INDEX uq_addresses_default_per_user
    ON users.addresses(user_id)
    WHERE is_default = TRUE AND deleted_at IS NULL;

CREATE TABLE users.login_history (
    id             UUID         NOT NULL DEFAULT uuid_generate_v7(),
    user_id        UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    login_provider VARCHAR(50)  NOT NULL DEFAULT 'Local',
    ip_address     VARCHAR(45),
    user_agent     TEXT,
    country        VARCHAR(2),
    city           VARCHAR(100),
    device_type    VARCHAR(20),
    device_info    JSONB,
    success        BOOLEAN      NOT NULL DEFAULT TRUE,
    failure_reason VARCHAR(100),
    created_at     TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Partições iniciais de login_history (trimestral — ajuste conforme volume esperado)
CREATE TABLE users.login_history_y2025_q1 PARTITION OF users.login_history
    FOR VALUES FROM ('2025-01-01') TO ('2025-04-01');
CREATE TABLE users.login_history_y2025_q2 PARTITION OF users.login_history
    FOR VALUES FROM ('2025-04-01') TO ('2025-07-01');
CREATE TABLE users.login_history_y2025_q3 PARTITION OF users.login_history
    FOR VALUES FROM ('2025-07-01') TO ('2025-10-01');
CREATE TABLE users.login_history_y2025_q4 PARTITION OF users.login_history
    FOR VALUES FROM ('2025-10-01') TO ('2026-01-01');
CREATE TABLE users.login_history_y2026_q1 PARTITION OF users.login_history
    FOR VALUES FROM ('2026-01-01') TO ('2026-04-01');
CREATE TABLE users.login_history_y2026_q2 PARTITION OF users.login_history
    FOR VALUES FROM ('2026-04-01') TO ('2026-07-01');
CREATE TABLE users.login_history_y2026_q3 PARTITION OF users.login_history
    FOR VALUES FROM ('2026-07-01') TO ('2026-10-01');
CREATE TABLE users.login_history_y2026_q4 PARTITION OF users.login_history
    FOR VALUES FROM ('2026-10-01') TO ('2027-01-01');

CREATE INDEX idx_login_history_user_id    ON users.login_history(user_id);
CREATE INDEX idx_login_history_created_at ON users.login_history(created_at DESC);

CREATE TABLE users.sessions (
    id                 UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id            UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    refresh_token_hash VARCHAR(512) NOT NULL,
    device_id          VARCHAR(100),
    device_name        VARCHAR(100),
    device_type        VARCHAR(20),
    ip_address         VARCHAR(45),
    country            VARCHAR(2),
    city               VARCHAR(100),
    is_current         BOOLEAN      DEFAULT FALSE,
    expires_at         TIMESTAMPTZ  NOT NULL,
    revoked_at         TIMESTAMPTZ,
    revoked_reason     VARCHAR(100),
    created_at         TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    last_activity_at   TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE UNIQUE INDEX uq_sessions_refresh_token ON users.sessions(refresh_token_hash);
CREATE INDEX idx_sessions_user_id_active ON users.sessions(user_id) WHERE revoked_at IS NULL;
CREATE INDEX idx_sessions_expires_at     ON users.sessions(expires_at) WHERE revoked_at IS NULL;

CREATE TABLE users.notifications (
    id                UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id           UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    title             VARCHAR(200) NOT NULL,
    message           TEXT         NOT NULL,
    notification_type VARCHAR(50)  NOT NULL,
    reference_type    VARCHAR(50),
    reference_id      UUID,
    action_url        TEXT,
    read_at           TIMESTAMPTZ,
    created_at        TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_notifications_user_unread ON users.notifications(user_id, created_at DESC)
    WHERE read_at IS NULL;

CREATE TABLE users.notification_preferences (
    id            UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id       UUID        NOT NULL UNIQUE REFERENCES users.users(id) ON DELETE CASCADE,
    email_enabled BOOLEAN     DEFAULT TRUE,
    push_enabled  BOOLEAN     DEFAULT TRUE,
    sms_enabled   BOOLEAN     DEFAULT FALSE,
    order_updates BOOLEAN     DEFAULT TRUE,
    promotions    BOOLEAN     DEFAULT TRUE,
    price_drops   BOOLEAN     DEFAULT TRUE,
    back_in_stock BOOLEAN     DEFAULT TRUE,
    newsletter    BOOLEAN     DEFAULT FALSE,
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- ============================================================
-- MÓDULO DE CATÁLOGO (catalog)
-- ============================================================

CREATE TABLE catalog.categories (
    id               UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    parent_id        UUID         REFERENCES catalog.categories(id) ON DELETE SET NULL,
    path             TEXT,
    depth            INT          NOT NULL DEFAULT 0,
    name             VARCHAR(100) NOT NULL,
    slug             VARCHAR(120) NOT NULL,
    description      TEXT,
    image_url        TEXT,
    meta_title       VARCHAR(70),
    meta_description VARCHAR(160),
    is_active        BOOLEAN      NOT NULL DEFAULT TRUE,
    sort_order       INT          DEFAULT 0,
    version          INT          NOT NULL DEFAULT 1,
    created_at       TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at       TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    deleted_at       TIMESTAMPTZ,
    CONSTRAINT chk_categories_name           CHECK (char_length(trim(name)) > 0),
    CONSTRAINT chk_categories_no_self_parent CHECK (parent_id IS NULL OR parent_id <> id),
    CONSTRAINT chk_categories_depth          CHECK (depth >= 0 AND depth <= 5)
);

CREATE UNIQUE INDEX uq_categories_slug ON catalog.categories(slug) WHERE deleted_at IS NULL;
CREATE INDEX idx_categories_parent_id  ON catalog.categories(parent_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_categories_path       ON catalog.categories(path) WHERE deleted_at IS NULL;
CREATE INDEX idx_categories_is_active  ON catalog.categories(is_active)
    WHERE is_active = TRUE AND deleted_at IS NULL;
CREATE INDEX idx_categories_name_trgm  ON catalog.categories USING GIN (name gin_trgm_ops);

CREATE TABLE catalog.brands (
    id          UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    name        VARCHAR(100) NOT NULL,
    slug        VARCHAR(120) NOT NULL,
    description TEXT,
    logo_url    TEXT,
    website_url TEXT,
    is_active   BOOLEAN      NOT NULL DEFAULT TRUE,
    sort_order  INT          DEFAULT 0,
    created_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    deleted_at  TIMESTAMPTZ,
    CONSTRAINT chk_brands_name CHECK (char_length(trim(name)) > 0)
);

CREATE UNIQUE INDEX uq_brands_slug ON catalog.brands(slug) WHERE deleted_at IS NULL;
CREATE UNIQUE INDEX uq_brands_name ON catalog.brands(LOWER(name)) WHERE deleted_at IS NULL;

CREATE TABLE catalog.products (
    id                  UUID                  PRIMARY KEY DEFAULT uuid_generate_v7(),
    category_id         UUID                  REFERENCES catalog.categories(id) ON DELETE SET NULL,
    brand_id            UUID                  REFERENCES catalog.brands(id) ON DELETE SET NULL,
    sku                 VARCHAR(100)          UNIQUE NOT NULL,
    slug                VARCHAR(200)          NOT NULL,
    barcode             VARCHAR(50),
    name                VARCHAR(150)          NOT NULL,
    short_description   VARCHAR(500),
    description         TEXT,
    price               DECIMAL(10,2)         NOT NULL,
    compare_at_price    DECIMAL(10,2),
    cost_price          DECIMAL(10,2),
    stock               INT                   NOT NULL DEFAULT 0,
    reserved_stock      INT                   NOT NULL DEFAULT 0,
    low_stock_threshold INT                   DEFAULT 10,
    weight_grams        INT,
    height_cm           DECIMAL(6,2),
    width_cm            DECIMAL(6,2),
    length_cm           DECIMAL(6,2),
    meta_title          VARCHAR(70),
    meta_description    VARCHAR(160),
    status              shared.product_status NOT NULL DEFAULT 'DRAFT',
    is_featured         BOOLEAN               DEFAULT FALSE,
    is_digital          BOOLEAN               DEFAULT FALSE,
    requires_shipping   BOOLEAN               DEFAULT TRUE,
    attributes          JSONB                 DEFAULT '{}',
    tags                TEXT[],
    version             INT                   NOT NULL DEFAULT 1,
    published_at        TIMESTAMPTZ,
    created_at          TIMESTAMPTZ           NOT NULL DEFAULT NOW(),
    updated_at          TIMESTAMPTZ           NOT NULL DEFAULT NOW(),
    deleted_at          TIMESTAMPTZ,
    CONSTRAINT chk_products_name          CHECK (char_length(trim(name)) > 0),
    CONSTRAINT chk_products_price         CHECK (price >= 0),
    CONSTRAINT chk_products_stock         CHECK (stock >= 0),
    CONSTRAINT chk_products_reserved      CHECK (reserved_stock >= 0),
    CONSTRAINT chk_products_compare_price CHECK (
        compare_at_price IS NULL OR compare_at_price > price
    )
);

CREATE UNIQUE INDEX uq_products_barcode ON catalog.products(barcode)
    WHERE barcode IS NOT NULL AND deleted_at IS NULL;
CREATE UNIQUE INDEX uq_products_slug    ON catalog.products(slug) WHERE deleted_at IS NULL;
CREATE INDEX idx_products_category_id  ON catalog.products(category_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_products_brand_id     ON catalog.products(brand_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_products_status       ON catalog.products(status) WHERE deleted_at IS NULL;
CREATE INDEX idx_products_is_featured  ON catalog.products(is_featured)
    WHERE is_featured = TRUE AND deleted_at IS NULL;
CREATE INDEX idx_products_attributes   ON catalog.products USING GIN (attributes);
CREATE INDEX idx_products_tags         ON catalog.products USING GIN (tags);
CREATE INDEX idx_products_name_trgm    ON catalog.products USING GIN (name gin_trgm_ops);
CREATE INDEX idx_products_price        ON catalog.products(price)
    WHERE status = 'ACTIVE' AND deleted_at IS NULL;
CREATE INDEX idx_products_updated_at   ON catalog.products(updated_at DESC)
    WHERE deleted_at IS NULL;
CREATE INDEX idx_products_low_stock    ON catalog.products(stock, low_stock_threshold)
    WHERE status = 'ACTIVE' AND deleted_at IS NULL;

CREATE TABLE catalog.product_images (
    id            UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    product_id    UUID        NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    url           TEXT        NOT NULL,
    alt_text      VARCHAR(255),
    url_thumbnail TEXT,
    url_medium    TEXT,
    url_large     TEXT,
    is_primary    BOOLEAN     DEFAULT FALSE,
    sort_order    INT         DEFAULT 0,
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_product_images_product_id ON catalog.product_images(product_id);

CREATE TABLE catalog.stock_movements (
    id             UUID                       NOT NULL DEFAULT uuid_generate_v7(),
    product_id     UUID                       NOT NULL REFERENCES catalog.products(id) ON DELETE RESTRICT,
    movement_type  shared.stock_movement_type NOT NULL,
    quantity       INT                        NOT NULL,
    reference_type VARCHAR(50),
    reference_id   UUID,
    stock_before   INT                        NOT NULL,
    stock_after    INT                        NOT NULL,
    reason         TEXT,
    performed_by   UUID REFERENCES users.users(id) ON DELETE SET NULL,
    created_at     TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Partições iniciais de stock_movements (trimestral)
CREATE TABLE catalog.stock_movements_y2025_q1 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2025-01-01') TO ('2025-04-01');
CREATE TABLE catalog.stock_movements_y2025_q2 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2025-04-01') TO ('2025-07-01');
CREATE TABLE catalog.stock_movements_y2025_q3 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2025-07-01') TO ('2025-10-01');
CREATE TABLE catalog.stock_movements_y2025_q4 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2025-10-01') TO ('2026-01-01');
CREATE TABLE catalog.stock_movements_y2026_q1 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2026-01-01') TO ('2026-04-01');
CREATE TABLE catalog.stock_movements_y2026_q2 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2026-04-01') TO ('2026-07-01');
CREATE TABLE catalog.stock_movements_y2026_q3 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2026-07-01') TO ('2026-10-01');
CREATE TABLE catalog.stock_movements_y2026_q4 PARTITION OF catalog.stock_movements
    FOR VALUES FROM ('2026-10-01') TO ('2027-01-01');

CREATE INDEX idx_stock_movements_product_id   ON catalog.stock_movements(product_id);
CREATE INDEX idx_stock_movements_performed_by ON catalog.stock_movements(performed_by)
    WHERE performed_by IS NOT NULL;
CREATE INDEX idx_stock_movements_reference    ON catalog.stock_movements(reference_type, reference_id)
    WHERE reference_id IS NOT NULL;

CREATE TABLE catalog.stock_reservations (
    id             UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    product_id     UUID        NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    reference_type VARCHAR(50) NOT NULL,
    reference_id   UUID        NOT NULL,
    quantity       INT         NOT NULL CHECK (quantity > 0),
    expires_at     TIMESTAMPTZ NOT NULL,
    released_at    TIMESTAMPTZ,
    created_at     TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_stock_reservation UNIQUE (product_id, reference_type, reference_id)
);

CREATE INDEX idx_stock_reservations_product_id ON catalog.stock_reservations(product_id);
CREATE INDEX idx_stock_reservations_expires    ON catalog.stock_reservations(expires_at)
    WHERE released_at IS NULL;

CREATE TABLE catalog.product_reviews (
    id                   UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    product_id           UUID        NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    user_id              UUID        NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    order_id             UUID,
    rating               INT         NOT NULL CHECK (rating >= 1 AND rating <= 5),
    title                VARCHAR(200),
    comment              TEXT,
    is_verified_purchase BOOLEAN     DEFAULT FALSE,
    is_approved          BOOLEAN     DEFAULT FALSE,
    seller_response      TEXT,
    seller_responded_at  TIMESTAMPTZ,
    created_at           TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at           TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    deleted_at           TIMESTAMPTZ
    -- NOTA: a constraint UNIQUE (product_id, user_id, order_id) foi removida
    -- intencionalmente. Com soft delete (deleted_at), uma constraint NOT NULL-ignorant
    -- colidiria em re-criação de reviews após deleção lógica.
    -- A unicidade é garantida pelos dois indexes parciais abaixo.
);

-- Garante 1 review por (produto, usuário, pedido) — exclui deletados
CREATE UNIQUE INDEX uq_product_review_user_order
    ON catalog.product_reviews(product_id, user_id, order_id)
    WHERE order_id IS NOT NULL AND deleted_at IS NULL;

-- Garante 1 review por (produto, usuário) sem pedido — exclui deletados
CREATE UNIQUE INDEX uq_product_review_user_no_order
    ON catalog.product_reviews(product_id, user_id)
    WHERE order_id IS NULL AND deleted_at IS NULL;

CREATE INDEX idx_product_reviews_product_id ON catalog.product_reviews(product_id)
    WHERE is_approved = TRUE AND deleted_at IS NULL;
CREATE INDEX idx_product_reviews_user_id    ON catalog.product_reviews(user_id);
CREATE INDEX idx_product_reviews_order_id   ON catalog.product_reviews(order_id)
    WHERE order_id IS NOT NULL;

CREATE TABLE catalog.user_favorites (
    id               UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id          UUID        NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    product_id       UUID        NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    product_snapshot JSONB,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_user_favorite_product UNIQUE (user_id, product_id)
);

CREATE INDEX idx_user_favorites_user_id    ON catalog.user_favorites(user_id);
CREATE INDEX idx_user_favorites_product_id ON catalog.user_favorites(product_id);

-- ============================================================
-- MÓDULO DE CARRINHO (cart)
-- ============================================================

CREATE TABLE cart.carts (
    id              UUID               PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id         UUID               REFERENCES users.users(id) ON DELETE CASCADE,
    session_id      VARCHAR(100),
    coupon_id       UUID,
    coupon_code     VARCHAR(50),
    discount_amount DECIMAL(10,2)      DEFAULT 0,
    status          shared.cart_status NOT NULL DEFAULT 'ACTIVE',
    ip_address      VARCHAR(45),
    user_agent      TEXT,
    version         INT                NOT NULL DEFAULT 1,
    expires_at      TIMESTAMPTZ,
    converted_at    TIMESTAMPTZ,
    created_at      TIMESTAMPTZ        NOT NULL DEFAULT NOW(),
    updated_at      TIMESTAMPTZ        NOT NULL DEFAULT NOW(),
    CONSTRAINT chk_cart_owner CHECK (user_id IS NOT NULL OR session_id IS NOT NULL)
);

CREATE INDEX idx_carts_user_id        ON cart.carts(user_id) WHERE user_id IS NOT NULL;
CREATE INDEX idx_carts_session_id     ON cart.carts(session_id) WHERE session_id IS NOT NULL;
CREATE INDEX idx_carts_expires_active ON cart.carts(expires_at)
    WHERE status = 'ACTIVE' AND expires_at IS NOT NULL;

CREATE TABLE cart.items (
    id                   UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    cart_id              UUID          NOT NULL REFERENCES cart.carts(id) ON DELETE CASCADE,
    product_id           UUID          NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    product_snapshot     JSONB         NOT NULL,
    quantity             INT           NOT NULL CHECK (quantity > 0),
    unit_price           DECIMAL(10,2) NOT NULL CHECK (unit_price >= 0),
    current_price        DECIMAL(10,2),
    price_changed_at     TIMESTAMPTZ,
    stock_reserved       BOOLEAN       DEFAULT FALSE,
    stock_reservation_id UUID          REFERENCES catalog.stock_reservations(id) ON DELETE SET NULL,
    added_at             TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
    updated_at           TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
    removed_at           TIMESTAMPTZ
);

CREATE UNIQUE INDEX uq_cart_item_product_active ON cart.items(cart_id, product_id)
    WHERE removed_at IS NULL;
CREATE INDEX idx_cart_items_cart_id    ON cart.items(cart_id);
CREATE INDEX idx_cart_items_product_id ON cart.items(product_id);

CREATE TABLE cart.activity_log (
    id              UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    cart_id         UUID        NOT NULL REFERENCES cart.carts(id) ON DELETE CASCADE,
    action          VARCHAR(50) NOT NULL,
    product_id      UUID        REFERENCES catalog.products(id) ON DELETE SET NULL,
    quantity_before INT,
    quantity_after  INT,
    metadata        JSONB,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_cart_activity_log_cart_id ON cart.activity_log(cart_id);

CREATE TABLE cart.saved_carts (
    id         UUID         PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id    UUID         NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    name       VARCHAR(100) NOT NULL DEFAULT 'Meu Carrinho Salvo',
    items      JSONB        NOT NULL,
    CONSTRAINT chk_saved_carts_items CHECK (jsonb_typeof(items) = 'array' AND jsonb_array_length(items) > 0),
    created_at TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    updated_at TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_saved_carts_user_id ON cart.saved_carts(user_id);

-- ============================================================
-- MÓDULO DE PEDIDOS (orders)
-- ============================================================

CREATE TABLE orders.orders (
    id                    UUID                       PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_number          VARCHAR(25)                UNIQUE NOT NULL DEFAULT orders.generate_order_number(),
    user_id               UUID                       NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    cart_id               UUID                       REFERENCES cart.carts(id) ON DELETE SET NULL,
    coupon_id             UUID,
    subtotal              DECIMAL(10,2)              NOT NULL CHECK (subtotal >= 0),
    discount_amount       DECIMAL(10,2)              NOT NULL DEFAULT 0,
    shipping_amount       DECIMAL(10,2)              NOT NULL DEFAULT 0,
    tax_amount            DECIMAL(10,2)              NOT NULL DEFAULT 0,
    total                 DECIMAL(10,2)              NOT NULL CHECK (total >= 0),
    coupon_snapshot       JSONB,
    status                shared.order_status        NOT NULL DEFAULT 'PENDING',
    shipping_address      JSONB                      NOT NULL,
    billing_address       JSONB,
    shipping_method       shared.shipping_method     NOT NULL DEFAULT 'STANDARD',
    shipping_carrier      VARCHAR(100),
    tracking_code         VARCHAR(100),
    tracking_url          TEXT,
    estimated_delivery_at TIMESTAMPTZ,
    payment_method        shared.payment_method_type NOT NULL,
    cancellation_reason   shared.cancellation_reason,
    cancellation_notes    TEXT,
    cancelled_by          UUID REFERENCES users.users(id) ON DELETE SET NULL,
    customer_notes        TEXT,
    internal_notes        TEXT,
    version               INT                        NOT NULL DEFAULT 1,
    paid_at               TIMESTAMPTZ,
    shipped_at            TIMESTAMPTZ,
    delivered_at          TIMESTAMPTZ,
    cancelled_at          TIMESTAMPTZ,
    refunded_at           TIMESTAMPTZ,
    created_at            TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    updated_at            TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    CONSTRAINT chk_orders_discount        CHECK (
        discount_amount >= 0 AND discount_amount <= subtotal
    ),
    CONSTRAINT chk_orders_total_integrity CHECK (
        ABS(total - (subtotal - discount_amount + shipping_amount + tax_amount)) < 0.01
    )
);

CREATE INDEX idx_orders_user_id      ON orders.orders(user_id);
CREATE INDEX idx_orders_status       ON orders.orders(status);
CREATE INDEX idx_orders_created_at   ON orders.orders(created_at DESC);
CREATE INDEX idx_orders_cancelled_by ON orders.orders(cancelled_by)
    WHERE cancelled_by IS NOT NULL;

CREATE TABLE orders.items (
    id               UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id         UUID          NOT NULL REFERENCES orders.orders(id) ON DELETE CASCADE,
    product_id       UUID          NOT NULL REFERENCES catalog.products(id) ON DELETE RESTRICT,
    product_snapshot JSONB         NOT NULL,
    unit_price       DECIMAL(10,2) NOT NULL CHECK (unit_price >= 0),
    quantity         INT           NOT NULL CHECK (quantity > 0),
    discount_amount  DECIMAL(10,2) NOT NULL DEFAULT 0,
    subtotal         DECIMAL(10,2) NOT NULL CHECK (subtotal >= 0),
    created_at       TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
    CONSTRAINT chk_order_items_subtotal CHECK (
        subtotal = ROUND((unit_price * quantity) - discount_amount, 2)
    )
);

CREATE INDEX idx_order_items_order_id   ON orders.items(order_id);
CREATE INDEX idx_order_items_product_id ON orders.items(product_id);

CREATE TABLE orders.status_history (
    id          UUID                PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id    UUID                NOT NULL REFERENCES orders.orders(id) ON DELETE CASCADE,
    from_status shared.order_status,
    to_status   shared.order_status NOT NULL,
    reason      TEXT,
    changed_by  UUID                REFERENCES users.users(id) ON DELETE SET NULL,
    metadata    JSONB,
    created_at  TIMESTAMPTZ         NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_status_history_order_id ON orders.status_history(order_id);

CREATE TABLE orders.tracking_events (
    id                UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id          UUID        NOT NULL REFERENCES orders.orders(id) ON DELETE CASCADE,
    event_code        VARCHAR(50) NOT NULL,
    event_description TEXT        NOT NULL,
    location          VARCHAR(200),
    city              VARCHAR(100),
    state             VARCHAR(2),
    occurred_at       TIMESTAMPTZ NOT NULL,
    created_at        TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_tracking_events_order_id ON orders.tracking_events(order_id);

CREATE TABLE orders.invoices (
    id             UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id       UUID        NOT NULL REFERENCES orders.orders(id) ON DELETE CASCADE,
    invoice_number VARCHAR(50) NOT NULL,
    invoice_key    VARCHAR(50),
    invoice_series VARCHAR(10),
    pdf_url        TEXT,
    xml_url        TEXT,
    issued_at      TIMESTAMPTZ NOT NULL,
    created_at     TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_invoices_order_id ON orders.invoices(order_id);
CREATE UNIQUE INDEX uq_invoices_number_series
    ON orders.invoices(invoice_number, COALESCE(invoice_series, ''));

CREATE TABLE orders.refunds (
    id                UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id          UUID          NOT NULL REFERENCES orders.orders(id) ON DELETE RESTRICT,
    amount            DECIMAL(10,2) NOT NULL CHECK (amount > 0),
    reason            TEXT          NOT NULL,
    refund_method     VARCHAR(50),
    -- payment_id preenchido após pagamento ser identificado; pode ser NULL no momento da criação
    payment_id        UUID,
    gateway_refund_id VARCHAR(100),
    status            shared.refund_status NOT NULL DEFAULT 'PENDING',
    processed_at      TIMESTAMPTZ,
    created_at        TIMESTAMPTZ   NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_order_refunds_order_id ON orders.refunds(order_id);

-- ============================================================
-- MÓDULO DE PAGAMENTOS (payments)
-- ============================================================

CREATE TABLE payments.user_methods (
    id                        UUID                       PRIMARY KEY DEFAULT uuid_generate_v7(),
    user_id                   UUID                       NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    gateway_customer_id       VARCHAR(100),
    gateway_payment_method_id VARCHAR(100)               NOT NULL,
    gateway_name              VARCHAR(50)                NOT NULL,
    method_type               shared.payment_method_type NOT NULL,
    card_brand                shared.card_brand,
    card_last_four            VARCHAR(4),
    card_holder_name          VARCHAR(150),
    card_expiration_month     VARCHAR(2),
    card_expiration_year      VARCHAR(4),
    wallet_type               VARCHAR(50),
    wallet_email              VARCHAR(255),
    is_default                BOOLEAN                    DEFAULT FALSE,
    is_valid                  BOOLEAN                    DEFAULT TRUE,
    version                   INT                        NOT NULL DEFAULT 1,
    last_used_at              TIMESTAMPTZ,
    created_at                TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    updated_at                TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    deleted_at                TIMESTAMPTZ,
    CONSTRAINT chk_card_data CHECK (
        (method_type NOT IN ('CREDIT_CARD', 'DEBIT_CARD'))
        OR (card_last_four IS NOT NULL AND card_brand IS NOT NULL)
    )
);

CREATE INDEX idx_user_methods_user_id ON payments.user_methods(user_id) WHERE deleted_at IS NULL;
CREATE UNIQUE INDEX uq_user_methods_gateway
    ON payments.user_methods(gateway_name, gateway_payment_method_id)
    WHERE deleted_at IS NULL;
CREATE UNIQUE INDEX uq_user_methods_default_per_user
    ON payments.user_methods(user_id)
    WHERE is_default = TRUE AND deleted_at IS NULL;

CREATE TABLE payments.payments (
    id                         UUID                       PRIMARY KEY DEFAULT uuid_generate_v7(),
    order_id                   UUID                       NOT NULL REFERENCES orders.orders(id) ON DELETE RESTRICT,
    user_id                    UUID                       NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    idempotency_key            VARCHAR(100)               UNIQUE NOT NULL,
    amount                     DECIMAL(10,2)              NOT NULL CHECK (amount > 0),
    currency                   VARCHAR(3)                 NOT NULL DEFAULT 'BRL',
    fee_amount                 DECIMAL(10,2)              DEFAULT 0,
    net_amount                 DECIMAL(10,2)              GENERATED ALWAYS AS (
                                                              amount - COALESCE(fee_amount, 0)
                                                          ) STORED,
    payment_method_type        shared.payment_method_type NOT NULL,
    saved_payment_method_id    UUID                       REFERENCES payments.user_methods(id) ON DELETE SET NULL,
    payment_method_snapshot    JSONB,
    installments               INT                        DEFAULT 1 CHECK (installments >= 1 AND installments <= 24),
    installment_amount         DECIMAL(10,2),
    gateway_name               VARCHAR(50)                NOT NULL,
    gateway_transaction_id     VARCHAR(100),
    gateway_authorization_code VARCHAR(50),
    gateway_response           JSONB,
    pix_qr_code                TEXT,
    pix_qr_code_url            TEXT,
    pix_expiration_at          TIMESTAMPTZ,
    boleto_url                 TEXT,
    boleto_barcode             VARCHAR(50),
    boleto_expiration_at       TIMESTAMPTZ,
    status                     shared.payment_status      NOT NULL DEFAULT 'PENDING',
    fraud_score                DECIMAL(5,2),
    fraud_analysis             JSONB,
    error_code                 VARCHAR(50),
    error_message              TEXT,
    version                    INT                        NOT NULL DEFAULT 1,
    authorized_at              TIMESTAMPTZ,
    captured_at                TIMESTAMPTZ,
    failed_at                  TIMESTAMPTZ,
    cancelled_at               TIMESTAMPTZ,
    refunded_at                TIMESTAMPTZ,
    expires_at                 TIMESTAMPTZ,
    created_at                 TIMESTAMPTZ                NOT NULL DEFAULT NOW(),
    updated_at                 TIMESTAMPTZ                NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_payments_order_id   ON payments.payments(order_id);
CREATE INDEX idx_payments_user_id    ON payments.payments(user_id);
CREATE INDEX idx_payments_status     ON payments.payments(status);
CREATE INDEX idx_payments_gateway_tx ON payments.payments(gateway_transaction_id)
    WHERE gateway_transaction_id IS NOT NULL;
CREATE INDEX idx_payments_expires_at ON payments.payments(expires_at)
    WHERE status = 'PENDING' AND expires_at IS NOT NULL;

-- [FIX] Garante que apenas um pagamento pode estar CAPTURED por pedido,
-- prevenindo dupla captura mesmo que a camada de negócio falhe.
CREATE UNIQUE INDEX uq_payments_captured_per_order
    ON payments.payments(order_id)
    WHERE status = 'CAPTURED';

CREATE TABLE payments.transactions (
    id                     UUID                    PRIMARY KEY DEFAULT uuid_generate_v7(),
    payment_id             UUID                    NOT NULL REFERENCES payments.payments(id) ON DELETE RESTRICT,
    transaction_type       shared.transaction_type NOT NULL,
    amount                 DECIMAL(10,2)           NOT NULL,
    gateway_transaction_id VARCHAR(100),
    gateway_response       JSONB,
    success                BOOLEAN                 NOT NULL,
    error_code             VARCHAR(50),
    error_message          TEXT,
    created_at             TIMESTAMPTZ             NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_transactions_payment_id ON payments.transactions(payment_id);

CREATE TABLE payments.refunds (
    id                UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    payment_id        UUID          NOT NULL REFERENCES payments.payments(id) ON DELETE RESTRICT,
    idempotency_key   VARCHAR(100)  UNIQUE NOT NULL,
    amount            DECIMAL(10,2) NOT NULL CHECK (amount > 0),
    reason            TEXT          NOT NULL,
    gateway_refund_id VARCHAR(100),
    gateway_response  JSONB,
    status            shared.refund_status NOT NULL DEFAULT 'PENDING',
    order_refund_id   UUID          REFERENCES orders.refunds(id) ON DELETE SET NULL,
    processed_at      TIMESTAMPTZ,
    created_at        TIMESTAMPTZ   NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_payment_refunds_payment_id ON payments.refunds(payment_id);

CREATE TABLE payments.chargebacks (
    id                    UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    payment_id            UUID          NOT NULL REFERENCES payments.payments(id) ON DELETE RESTRICT,
    gateway_chargeback_id VARCHAR(100),
    reason_code           VARCHAR(50),
    reason_description    TEXT,
    amount                DECIMAL(10,2) NOT NULL,
    evidence_submitted    BOOLEAN       DEFAULT FALSE,
    evidence_due_at       TIMESTAMPTZ,
    status                shared.chargeback_status NOT NULL DEFAULT 'OPEN',
    result                VARCHAR(50),
    opened_at             TIMESTAMPTZ   NOT NULL,
    resolved_at           TIMESTAMPTZ,
    created_at            TIMESTAMPTZ   NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_chargebacks_payment_id ON payments.chargebacks(payment_id);
CREATE INDEX idx_chargebacks_status     ON payments.chargebacks(status) WHERE status = 'OPEN';

CREATE TABLE payments.webhooks (
    id                UUID         NOT NULL DEFAULT uuid_generate_v7(),
    gateway_name      VARCHAR(50)  NOT NULL,
    -- [FIX] gateway_event_id garante idempotência: gateways reenviam webhooks em falha.
    -- O index único abaixo previne processamento duplicado do mesmo evento.
    gateway_event_id  VARCHAR(100),
    event_type        VARCHAR(100) NOT NULL,
    payload           JSONB        NOT NULL,
    headers           JSONB,
    processed         BOOLEAN      DEFAULT FALSE,
    processed_at      TIMESTAMPTZ,
    error_message     TEXT,
    payment_id        UUID         REFERENCES payments.payments(id) ON DELETE SET NULL,
    received_at       TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    PRIMARY KEY (id, received_at)
) PARTITION BY RANGE (received_at);

-- Partições iniciais de webhooks (trimestral)
CREATE TABLE payments.webhooks_y2025_q1 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2025-01-01') TO ('2025-04-01');
CREATE TABLE payments.webhooks_y2025_q2 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2025-04-01') TO ('2025-07-01');
CREATE TABLE payments.webhooks_y2025_q3 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2025-07-01') TO ('2025-10-01');
CREATE TABLE payments.webhooks_y2025_q4 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2025-10-01') TO ('2026-01-01');
CREATE TABLE payments.webhooks_y2026_q1 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2026-01-01') TO ('2026-04-01');
CREATE TABLE payments.webhooks_y2026_q2 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2026-04-01') TO ('2026-07-01');
CREATE TABLE payments.webhooks_y2026_q3 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2026-07-01') TO ('2026-10-01');
CREATE TABLE payments.webhooks_y2026_q4 PARTITION OF payments.webhooks
    FOR VALUES FROM ('2026-10-01') TO ('2027-01-01');

CREATE INDEX idx_webhooks_pending    ON payments.webhooks(received_at ASC) WHERE processed = FALSE;
CREATE INDEX idx_webhooks_payment_id ON payments.webhooks(payment_id) WHERE payment_id IS NOT NULL;
-- [FIX] Previne reprocessamento de evento duplicado por gateway
CREATE UNIQUE INDEX uq_webhooks_gateway_event
    ON payments.webhooks(gateway_name, gateway_event_id)
    WHERE gateway_event_id IS NOT NULL;

-- ============================================================
-- MÓDULO DE CUPONS (coupons)
-- ============================================================

CREATE TABLE coupons.coupons (
    id                  UUID                 PRIMARY KEY DEFAULT uuid_generate_v7(),
    code                CITEXT               UNIQUE NOT NULL,
    name                VARCHAR(100)         NOT NULL,
    description         TEXT,
    discount_type       shared.coupon_type   NOT NULL,
    discount_value      DECIMAL(10,2)        NOT NULL CHECK (discount_value > 0),
    max_discount_amount DECIMAL(10,2),
    scope               shared.coupon_scope  NOT NULL DEFAULT 'ALL',
    min_purchase_amount DECIMAL(10,2)        DEFAULT 0,
    min_items_quantity  INT                  DEFAULT 1,
    buy_quantity        INT,
    get_quantity        INT,
    valid_from          TIMESTAMPTZ          NOT NULL,
    valid_until         TIMESTAMPTZ          NOT NULL,
    max_uses            INT,
    current_uses        INT                  NOT NULL DEFAULT 0,
    max_uses_per_user   INT                  DEFAULT 1,
    is_stackable        BOOLEAN              DEFAULT FALSE,
    status              shared.coupon_status NOT NULL DEFAULT 'DRAFT',
    created_by          UUID                 REFERENCES users.users(id) ON DELETE SET NULL,
    metadata            JSONB                DEFAULT '{}',
    version             INT                  NOT NULL DEFAULT 1,
    created_at          TIMESTAMPTZ          NOT NULL DEFAULT NOW(),
    updated_at          TIMESTAMPTZ          NOT NULL DEFAULT NOW(),
    deleted_at          TIMESTAMPTZ,
    CONSTRAINT chk_coupon_code_format CHECK (char_length(code) >= 3 AND char_length(code) <= 50),
    CONSTRAINT chk_coupon_percentage  CHECK (discount_type != 'PERCENTAGE' OR discount_value <= 100),
    CONSTRAINT chk_coupon_validity    CHECK (valid_until > valid_from),
    CONSTRAINT chk_coupon_max_uses    CHECK (max_uses IS NULL OR max_uses > 0),
    CONSTRAINT chk_coupon_buy_get     CHECK (
        discount_type != 'BUY_X_GET_Y'
        OR (
            buy_quantity IS NOT NULL AND get_quantity IS NOT NULL
            AND buy_quantity > 0 AND get_quantity > 0
        )
    ),
    CONSTRAINT chk_coupon_current_uses CHECK (
        max_uses IS NULL OR current_uses <= max_uses
    )
);

CREATE INDEX idx_coupons_active ON coupons.coupons(valid_from, valid_until)
    WHERE status = 'ACTIVE' AND deleted_at IS NULL;

CREATE TABLE coupons.eligible_categories (
    id          UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    coupon_id   UUID        NOT NULL REFERENCES coupons.coupons(id) ON DELETE CASCADE,
    category_id UUID        NOT NULL REFERENCES catalog.categories(id) ON DELETE CASCADE,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_coupon_category UNIQUE (coupon_id, category_id)
);

CREATE INDEX idx_eligible_categories_coupon_id ON coupons.eligible_categories(coupon_id);

CREATE TABLE coupons.eligible_products (
    id         UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    coupon_id  UUID        NOT NULL REFERENCES coupons.coupons(id) ON DELETE CASCADE,
    product_id UUID        NOT NULL REFERENCES catalog.products(id) ON DELETE CASCADE,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_coupon_product UNIQUE (coupon_id, product_id)
);

CREATE INDEX idx_eligible_products_coupon_id ON coupons.eligible_products(coupon_id);

CREATE TABLE coupons.eligible_users (
    id         UUID        PRIMARY KEY DEFAULT uuid_generate_v7(),
    coupon_id  UUID        NOT NULL REFERENCES coupons.coupons(id) ON DELETE CASCADE,
    user_id    UUID        NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_coupon_user UNIQUE (coupon_id, user_id)
);

CREATE INDEX idx_eligible_users_coupon_id ON coupons.eligible_users(coupon_id);
CREATE INDEX idx_eligible_users_user_id   ON coupons.eligible_users(user_id);

CREATE TABLE coupons.usages (
    id              UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    coupon_id       UUID          NOT NULL REFERENCES coupons.coupons(id) ON DELETE RESTRICT,
    user_id         UUID          REFERENCES users.users(id) ON DELETE SET NULL,
    order_id        UUID          NOT NULL REFERENCES orders.orders(id) ON DELETE RESTRICT,
    discount_amount DECIMAL(10,2) NOT NULL CHECK (discount_amount >= 0),
    order_subtotal  DECIMAL(10,2) NOT NULL,
    used_at         TIMESTAMPTZ   NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_coupon_usages_coupon_user ON coupons.usages(coupon_id, user_id);
CREATE INDEX idx_coupon_usages_user_id     ON coupons.usages(user_id) WHERE user_id IS NOT NULL;
CREATE INDEX idx_coupon_usages_order_id    ON coupons.usages(order_id);

CREATE TABLE coupons.reservations (
    id              UUID          PRIMARY KEY DEFAULT uuid_generate_v7(),
    coupon_id       UUID          NOT NULL REFERENCES coupons.coupons(id) ON DELETE CASCADE,
    cart_id         UUID          NOT NULL REFERENCES cart.carts(id) ON DELETE CASCADE,
    user_id         UUID          REFERENCES users.users(id) ON DELETE SET NULL,
    discount_amount DECIMAL(10,2) NOT NULL CHECK (discount_amount >= 0),
    expires_at      TIMESTAMPTZ   NOT NULL,
    released_at     TIMESTAMPTZ,
    converted_at    TIMESTAMPTZ,
    created_at      TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
    CONSTRAINT uq_coupon_reservation UNIQUE (coupon_id, cart_id)
);

CREATE INDEX idx_coupon_reservations_coupon_id ON coupons.reservations(coupon_id);
CREATE INDEX idx_coupon_reservations_expires   ON coupons.reservations(expires_at)
    WHERE released_at IS NULL AND converted_at IS NULL;

-- ============================================================
-- INFRAESTRUTURA DE EVENTOS E AUDITORIA (shared)
-- ============================================================

CREATE TABLE shared.domain_events (
    id             UUID         NOT NULL DEFAULT uuid_generate_v7(),
    module         VARCHAR(50)  NOT NULL,
    aggregate_type VARCHAR(100) NOT NULL,
    aggregate_id   UUID         NOT NULL,
    event_type     TEXT         NOT NULL,
    payload        JSONB        NOT NULL,
    created_at     TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    processed_at   TIMESTAMPTZ,
    error_message  TEXT,
    retry_count    INT          DEFAULT 0,
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Partições iniciais de domain_events (trimestral)
CREATE TABLE shared.domain_events_y2025_q1 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2025-01-01') TO ('2025-04-01');
CREATE TABLE shared.domain_events_y2025_q2 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2025-04-01') TO ('2025-07-01');
CREATE TABLE shared.domain_events_y2025_q3 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2025-07-01') TO ('2025-10-01');
CREATE TABLE shared.domain_events_y2025_q4 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2025-10-01') TO ('2026-01-01');
CREATE TABLE shared.domain_events_y2026_q1 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2026-01-01') TO ('2026-04-01');
CREATE TABLE shared.domain_events_y2026_q2 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2026-04-01') TO ('2026-07-01');
CREATE TABLE shared.domain_events_y2026_q3 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2026-07-01') TO ('2026-10-01');
CREATE TABLE shared.domain_events_y2026_q4 PARTITION OF shared.domain_events
    FOR VALUES FROM ('2026-10-01') TO ('2027-01-01');

CREATE INDEX idx_domain_events_unprocessed ON shared.domain_events(created_at ASC)
    WHERE processed_at IS NULL;
CREATE INDEX idx_domain_events_consumer    ON shared.domain_events(module, event_type, created_at)
    WHERE processed_at IS NULL;
CREATE INDEX idx_domain_events_aggregate   ON shared.domain_events(aggregate_type, aggregate_id);

CREATE TABLE shared.processed_events (
    id           UUID         PRIMARY KEY,
    event_type   VARCHAR(100) NOT NULL,
    module       VARCHAR(50)  NOT NULL,
    processed_at TIMESTAMPTZ  NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_processed_events_module ON shared.processed_events(module, processed_at DESC);

CREATE TABLE shared.audit_logs (
    id          UUID         NOT NULL DEFAULT uuid_generate_v7(),
    module      VARCHAR(50)  NOT NULL,
    entity_type VARCHAR(100) NOT NULL,
    entity_id   UUID         NOT NULL,
    action      VARCHAR(50)  NOT NULL,
    old_values  JSONB,
    new_values  JSONB,
    user_id     UUID,
    ip_address  VARCHAR(45),
    user_agent  TEXT,
    created_at  TIMESTAMPTZ  NOT NULL DEFAULT NOW(),
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Partições iniciais de audit_logs (trimestral)
CREATE TABLE shared.audit_logs_y2025_q1 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2025-01-01') TO ('2025-04-01');
CREATE TABLE shared.audit_logs_y2025_q2 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2025-04-01') TO ('2025-07-01');
CREATE TABLE shared.audit_logs_y2025_q3 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2025-07-01') TO ('2025-10-01');
CREATE TABLE shared.audit_logs_y2025_q4 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2025-10-01') TO ('2026-01-01');
CREATE TABLE shared.audit_logs_y2026_q1 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2026-01-01') TO ('2026-04-01');
CREATE TABLE shared.audit_logs_y2026_q2 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2026-04-01') TO ('2026-07-01');
CREATE TABLE shared.audit_logs_y2026_q3 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2026-07-01') TO ('2026-10-01');
CREATE TABLE shared.audit_logs_y2026_q4 PARTITION OF shared.audit_logs
    FOR VALUES FROM ('2026-10-01') TO ('2027-01-01');

CREATE INDEX idx_audit_logs_entity  ON shared.audit_logs(entity_type, entity_id);
CREATE INDEX idx_audit_logs_user_id ON shared.audit_logs(user_id) WHERE user_id IS NOT NULL;
CREATE INDEX idx_audit_logs_created ON shared.audit_logs(created_at DESC);

-- ============================================================
-- FOREIGN KEYS TARDIAS
-- ============================================================

ALTER TABLE cart.carts
    ADD CONSTRAINT fk_carts_coupon
    FOREIGN KEY (coupon_id) REFERENCES coupons.coupons(id) ON DELETE SET NULL;

CREATE INDEX idx_carts_coupon_id ON cart.carts(coupon_id) WHERE coupon_id IS NOT NULL;

ALTER TABLE orders.orders
    ADD CONSTRAINT fk_orders_coupon
    FOREIGN KEY (coupon_id) REFERENCES coupons.coupons(id) ON DELETE SET NULL;

CREATE INDEX idx_orders_coupon_id ON orders.orders(coupon_id) WHERE coupon_id IS NOT NULL;

ALTER TABLE orders.refunds
    ADD CONSTRAINT fk_order_refunds_payment
    FOREIGN KEY (payment_id) REFERENCES payments.payments(id) ON DELETE SET NULL;

CREATE INDEX idx_order_refunds_payment_id ON orders.refunds(payment_id)
    WHERE payment_id IS NOT NULL;

ALTER TABLE catalog.product_reviews
    ADD CONSTRAINT fk_reviews_order
    FOREIGN KEY (order_id) REFERENCES orders.orders(id) ON DELETE SET NULL;

-- ============================================================
-- NOTA SOBRE MANUTENÇÃO DE PARTIÇÕES
-- ============================================================
-- As partições acima cobrem 2025 e 2026 (trimestral).
-- Recomenda-se fortemente o uso de pg_partman para criação
-- automática de partições futuras e detach/drop de antigas.
-- Exemplo de configuração:
--
--   SELECT partman.create_parent(
--       p_parent_table  => 'shared.domain_events',
--       p_control       => 'created_at',
--       p_type          => 'range',
--       p_interval      => '3 months',
--       p_premake       => 4
--   );
--
-- O mesmo vale para: users.login_history, catalog.stock_movements,
-- shared.audit_logs e payments.webhooks.
-- ============================================================